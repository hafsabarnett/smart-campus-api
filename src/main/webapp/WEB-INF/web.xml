<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Smart Campus API</display-name>

    <servlet>
        <servlet-name>SmartCampusApplication</servlet-name>
        <servlet-class>
            org.glassfish.jersey.servlet.ServletContainer
        </servlet-class>

        <!-- Scan the entire com.smartcampus package for @Path, 
             @Provider and filter classes automatically -->
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>com.smartcampus</param-value>
        </init-param>

        <!-- Enable Jackson JSON support -->
        <init-param>
            <param-name>jersey.config.server.provider.classnames</param-name>
            <param-value>
                org.glassfish.jersey.jackson.JacksonFeature
            </param-value>
        </init-param>

        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>SmartCampusApplication</servlet-name>
        <!-- All requests to /api/v1/* are handled by Jersey -->
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>